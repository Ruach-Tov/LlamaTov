+
+/// Find libdevice.10.bc in standard CUDA toolkit locations.
+/// Searches CUDA_PATH, /usr/local/cuda, and nix store paths.
+fn find_cuda_libdevice() -> anyhow::Result<std::path::PathBuf> {
+    let candidates = [
+        // CUDA_PATH environment variable
+        std::env::var("CUDA_PATH").ok().map(|p| {
+            std::path::PathBuf::from(p).join("nvvm/libdevice/libdevice.10.bc")
+        }),
+        // Standard Linux install
+        Some(std::path::PathBuf::from("/usr/local/cuda/nvvm/libdevice/libdevice.10.bc")),
+        // NixOS
+        std::env::var("CUDA_MERGED").ok().map(|p| {
+            std::path::PathBuf::from(p).join("nvvm/libdevice/libdevice.10.bc")
+        }),
+    ];
+    for candidate in candidates.iter().flatten() {
+        if candidate.exists() {
+            return Ok(candidate.clone());
+        }
+    }
+    // Search common nix store paths
+    if let Ok(entries) = std::fs::read_dir("/nix/store") {
+        for entry in entries.flatten() {
+            let path = entry.path().join("nvvm/libdevice/libdevice.10.bc");
+            if path.exists() {
+                return Ok(path);
+            }
+        }
+    }
+    Err(anyhow::anyhow!(
+        "Could not find libdevice.10.bc. Set CUDA_PATH or CUDA_MERGED."
+    ))
+}
