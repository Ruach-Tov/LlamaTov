  %l7_s01 = add i32 %l7_s0, %l7_s1
  %l7_s23 = add i32 %l7_s2, %l7_s3
  %lane7 = add i32 %l7_s01, %l7_s23
  %L0v = insertelement <8 x i32> undef, i32 %lane0, i32 0
  %L1v = insertelement <8 x i32> %L0v, i32 %lane1, i32 1
  %L2v = insertelement <8 x i32> %L1v, i32 %lane2, i32 2
  %L3v = insertelement <8 x i32> %L2v, i32 %lane3, i32 3
  %L4v = insertelement <8 x i32> %L3v, i32 %lane4, i32 4
  %L5v = insertelement <8 x i32> %L4v, i32 %lane5, i32 5
  %L6v = insertelement <8 x i32> %L5v, i32 %lane6, i32 6
  %L7v = insertelement <8 x i32> %L6v, i32 %lane7, i32 7
  %lanes = add <8 x i32> %L7v, zeroinitializer
  %pf = sitofp <8 x i32> %lanes to <8 x float>
  %bi = sext i32 %b to i64
  %b1i = sext i32 %b1 to i64
  %wd0p = getelementptr float, float* %wd, i64 %bi
  %ad0p = getelementptr float, float* %ad, i64 %bi
  %wd1p = getelementptr float, float* %wd, i64 %b1i
  %ad1p = getelementptr float, float* %ad, i64 %b1i
  %wd0 = load float, float* %wd0p, align 4
  %ad0 = load float, float* %ad0p, align 4
  %wd1 = load float, float* %wd1p, align 4
  %ad1 = load float, float* %ad1p, align 4
  %s0 = fmul float %wd0, %ad0
  %s1 = fmul float %wd1, %ad1
  %d0 = insertelement <8 x float> undef, float %s0, i32 0
  %d1 = insertelement <8 x float> %d0, float %s0, i32 1
  %d2 = insertelement <8 x float> %d1, float %s0, i32 2
  %d3 = insertelement <8 x float> %d2, float %s0, i32 3
  %d4 = insertelement <8 x float> %d3, float %s1, i32 4
  %d5 = insertelement <8 x float> %d4, float %s1, i32 5
  %d6 = insertelement <8 x float> %d5, float %s1, i32 6
  %deltas = insertelement <8 x float> %d6, float %s1, i32 7
  %prodv = fmul <8 x float> %deltas, %pf
  %accv.next = fadd <8 x float> %accv, %prodv
  br label %blk.latch

blk.latch:
  %b.next = add i32 %b, 2
  br label %blk.header

tail:
  %lo = shufflevector <8 x float> %accv, <8 x float> undef, <4 x i32> <i32 0, i32 1, i32 2, i32 3>
  %hi = shufflevector <8 x float> %accv, <8 x float> undef, <4 x i32> <i32 4, i32 5, i32 6, i32 7>
  %res4 = fadd <4 x float> %lo, %hi
  %movehl = shufflevector <4 x float> %res4, <4 x float> undef, <4 x i32> <i32 2, i32 3, i32 2, i32 3>
  %res2 = fadd <4 x float> %res4, %movehl
  %r0 = extractelement <4 x float> %res2, i32 0
  %r1 = extractelement <4 x float> %res2, i32 1
  %sum = fadd float %r0, %r1
  ret float %sum
}
